// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "linux-arm64-openssl-1.1.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  password       String
  twoFA          Boolean   @default(false)
  twoFASecret    String?
  twoFABackup    String?
  resetOTP       String?
  resetOTPExpiry DateTime?
  profile        Profile?
}

model Profile {
  id       Int       @id
  user     User      @relation(fields: [id], references: [id])
  email    String    @unique
  avatar   String?
  username String    @unique
  fullname String
  dob      DateTime?
  region   String?
  bio      String?

  // XP and progression
  totalXP    Int @default(0)
  level      Int @default(1)
  totalWins  Int @default(0)
  totalLosses Int @default(0)
  totalDraws Int @default(0)

  tournaments    Tournament[]
  tournamentsWon Tournament[] @relation("TournamentWinner")

  matchesAsPlayer1 Match[] @relation("MatchPlayer1")
  matchesAsPlayer2 Match[] @relation("MatchPlayer2")

  // user sent these requests
  requester Friendship[] @relation("RequesterRelations")
  // user received these requests
  addressee Friendship[] @relation("AddresseeRelations")

  // Messages sent by this user
  sentMessages Message[] @relation("MessageSender")
  // Messages received by this user
  receivedMessages Message[] @relation("MessageReceiver")

  // Users this profile has blocked
  blockedUsers Block[] @relation("Blocker")
  // Users who have blocked this profile
  blockedBy Block[] @relation("Blocked")

  // Achievements
  achievements Achievement[]
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Friendship {
  id Int @id @default(autoincrement())

  requester   Profile @relation("RequesterRelations", fields: [requesterId], references: [id])
  requesterId Int

  addressee   Profile @relation("AddresseeRelations", fields: [addresseeId], references: [id])
  addresseeId Int

  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now())

  @@unique([requesterId, addresseeId])
}

model Tournament {
  id       Int      @id @default(autoincrement())
  date     DateTime @default(now())
  winnerId Int?
  winner   Profile?    @relation("TournamentWinner", fields: [winnerId], references: [id])
  players  Profile[]
  matches  Match[]
}

enum MatchMode {
  LOCAL
  LOCAL_TOURNAMENT
  REMOTE
  REMOTE_TOURNAMENT
  AI
}

model Match {
  id Int @id @default(autoincrement())

  // Stable runtime identifier used to dedupe repeated save attempts for the same logical match.
  externalMatchId String? @unique

  // Runtime tournament key used by in-memory local/remote tournament flows.
  // This preserves the actual tournament identifier even when no Prisma Tournament row exists.
  externalTournamentId String?

  // Player 1 is always the Host/LoggedIn user
  player1Id Int
  player1   Profile @relation("MatchPlayer1", fields: [player1Id], references: [id])

  // Player 2 is Optional (Nullable) to support Local Guest players
  player2Id Int?
  player2   Profile? @relation("MatchPlayer2", fields: [player2Id], references: [id])

  score1 Int
  score2 Int

  // Duration of the match in seconds (null for matches recorded before this field was added)
  durationSeconds Int?

  // Track if it is local/remote/ai
  mode MatchMode @default(REMOTE)

  // Add '?' to make it optional
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])
  tournamentId Int?

  createdAt DateTime @default(now())

  @@index([externalTournamentId])
}

model Message {
  id Int @id @default(autoincrement())

  sender   Profile @relation("MessageSender", fields: [senderId], references: [id])
  senderId Int

  recipient   Profile @relation("MessageReceiver", fields: [recipientId], references: [id])
  recipientId Int

  content   String
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([senderId, recipientId])
  @@index([recipientId, senderId])
}

model Block {
  id Int @id @default(autoincrement())

  blocker   Profile @relation("Blocker", fields: [blockerId], references: [id])
  blockerId Int

  blocked   Profile @relation("Blocked", fields: [blockedId], references: [id])
  blockedId Int

  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

enum AchievementType {
  FIRST_WIN
  LEVEL_5
  LEVEL_10
  TOTAL_WINS_10
  TOTAL_WINS_50
  DRAW_MATCH
  TOURNAMENT_WIN
}

model Achievement {
  id Int @id @default(autoincrement())

  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId Int

  achievementKey AchievementType
  unlockedAt DateTime @default(now())

  @@unique([profileId, achievementKey])
}
