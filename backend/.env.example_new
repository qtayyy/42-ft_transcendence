JWT_SECRET=
TEMP_JWT_SECRET=
EMAIL_USER=
EMAIL_PASSWORD=
GOOGLE_CLIENT_ID="your-production-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_ID_DEV="your-dev-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-production-secret"
GOOGLE_CLIENT_SECRET_DEV="GOCSPX-your-dev-secret"
SECURITY_PEPPER=
SALT_ROUNDS=12
# --- Google OAuth mode (change this when switching) ---
# localhost:  APP_URL=https://localhost:8443
# ngrok:      APP_URL=https://<your-subdomain>.ngrok-free.app
# Must match the redirect URI registered in Google Cloud Console.
APP_URL=https://localhost:8443

DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
#  DATABASE_URL="file:/data/database.db"

# LAN mode: set this to your machine's WiFi IP (run: ipconfig getifaddr en0)
HOST_IP=
